# Environment Configuration
# Copy this file to .env and fill in your values

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./game_rental.db

# JWT - Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-in-production-please-use-env-variable

# WeChat (Get from https://mp.weixin.qq.com/)
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret

# Commission
COMMISSION_RATE=0.10

# Verification deadline (hours)
VERIFY_DEADLINE_HOURS=48

# Encryption key for sensitive data (32 bytes)
ENCRYPTION_KEY=your-32-byte-encryption-key-here
